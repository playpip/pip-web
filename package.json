{
  "name": "clean-poker",
  "version": "1.1.12",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/stamp-sw.mjs",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome check --write --unsafe .",
